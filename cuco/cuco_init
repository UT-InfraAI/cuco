#!/usr/bin/env python3
"""
CUCo workload scaffolding CLI.

Usage:
    cuco_init --setup                       # one-time cluster config
    cuco_init /path/to/seed.cu              # scaffold a new workload
    cuco_init /path/to/seed.cu --np 4       # with custom MPI rank count
"""

import argparse
import os
import sys
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))


def main():
    parser = argparse.ArgumentParser(
        description="Scaffold a new CUCo workload from a seed CUDA kernel.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  cuco_init --setup                       One-time cluster auto-detection
  cuco_init my_kernel.cu                  Create workloads/my_kernel/
  cuco_init my_kernel.cu --np 4           Use 4 MPI ranks
  cuco_init my_kernel.cu --generations 100
""",
    )
    parser.add_argument(
        "seed_file", nargs="?", default=None,
        help="Path to the seed .cu file.",
    )
    parser.add_argument(
        "--setup", action="store_true",
        help="Run interactive cluster setup (auto-detect CUDA/NCCL/MPI/GPU, save to ~/.cuco/site.yaml).",
    )
    parser.add_argument("--name", type=str, default=None, help="Workload name (default: seed filename stem).")
    parser.add_argument("--np", type=int, default=None, help="MPI rank count (default: from site config, typically = GPU count).")
    parser.add_argument("--generations", type=int, default=50, help="Default number of generations (default: 50).")
    parser.add_argument("--dir", type=str, default=None, help="Output directory (default: workloads/<name>/).")

    args = parser.parse_args()

    # --- Setup mode ---
    if args.setup:
        from cuco.site_config import interactive_setup
        interactive_setup()
        return

    # --- Scaffold mode ---
    if args.seed_file is None:
        parser.error("Please provide a seed .cu file, or use --setup for cluster configuration.")

    seed_path = Path(args.seed_file).resolve()
    if not seed_path.exists():
        parser.error(f"Seed file not found: {seed_path}")
    if not seed_path.suffix == ".cu":
        parser.error(f"Seed file must be a .cu file, got: {seed_path.name}")

    workload_name = args.name or seed_path.stem

    # Determine project root (where workloads/ lives).
    # Use the cuco package location rather than __file__, since __file__
    # points to .venv/bin/ when running as an installed CLI script.
    import cuco
    project_root = Path(cuco.__file__).resolve().parent.parent
    if args.dir:
        output_dir = Path(args.dir).resolve()
    else:
        output_dir = project_root / "workloads" / workload_name

    # Ensure site config exists (auto-detect if needed)
    from cuco.site_config import get_or_detect_config, DEFAULT_NP
    site_cfg = get_or_detect_config()

    mpi_np = args.np if args.np is not None else DEFAULT_NP

    # Validate seed file
    from cuco.init_workload import validate_seed, scaffold, print_summary
    checks = validate_seed(seed_path)

    # Scaffold
    try:
        scaffold(
            seed_path=seed_path,
            workload_name=workload_name,
            output_dir=output_dir,
            mpi_np=mpi_np,
            num_generations=args.generations,
            site_cfg=site_cfg,
        )
    except FileExistsError as e:
        print(f"\n  Error: {e}", file=sys.stderr)
        print(f"  Remove it first or use --dir to specify a different location.\n", file=sys.stderr)
        sys.exit(1)

    # Print summary
    print_summary(
        output_dir=output_dir,
        workload_name=workload_name,
        seed_name=seed_path.name,
        mpi_np=mpi_np,
        num_generations=args.generations,
        checks=checks,
        site_cfg=site_cfg,
    )


if __name__ == "__main__":
    main()
